% --- 放宽 LaTeX 浮动体排版限制的全局参数 ---
\renewcommand{\textfraction}{0.1}      % 页面中必须保留的文字比例最小值（默认通常是 0.2，改小允许图片占更大空间）
\renewcommand{\topfraction}{0.9}       % 页面顶部允许被图片占据的最大比例（默认 0.7）
\renewcommand{\bottomfraction}{0.9}    % 页面底部允许被图片占据的最大比例（默认 0.3）
\renewcommand{\floatpagefraction}{0.85}% 触发“纯图片页”的判定阈值（极其关键：默认 0.5，改大意味着只要图没占满 85%，就必须排版文字）
\setcounter{topnumber}{3}              % 页面顶部最多允许放几张图（默认 2）
\setcounter{bottomnumber}{3}           % 页面底部最多允许放几张图（默认 1）
\setcounter{totalnumber}{5}            % 一页总共最多允许放几张图（默认 3）




